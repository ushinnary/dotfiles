{
  "git_panel": {
    "tree_view": true
  },
  "vim_mode": true,
  "ui_font_weight": 500.0,
  "ui_font_family": "Quicksand",
  "buffer_font_family": "Google Sans Code",
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha (Blur)"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "load_direnv": "shell_hook",
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "path_lookup": true
      },
      "initialization_options": {
        "check": {
          "command": "clippy"
        }
      }
    },
    "nix": {
      "binary": {
        "path_lookup": true
      }
    }
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "html": true,
    "nix": true,
    "nu": true,
    "rust": true,
    "surrealql": true,
    "toml": true,
    "biome": true,
    "catppuccin-blur": true,
    "catppuccin-icons": true,
    "csharp": true,
    "csv": true,
    "docker-compose": true,
    "dockerfile": true,
    "emmet": true,
    "ini": true,
    "lua": true,
    "powershell": true,
    "scss": true,
    "sql": true,
    "svelte": true,
    "vue": true,
    "xml": true
  }
}