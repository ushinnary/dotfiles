{
  "minimum_split_diff_width": 0.0,
  "agent_servers": {
    "KiloCode": {
      "type": "custom",
      "command": "/run/current-system/sw/bin/kilocode",
    },
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": false,
    },
  },
  "project_panel": {
    "git_status_indicator": true,
    "diagnostic_badges": false,
    "dock": "right",
  },
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "allow_rewrap": "anywhere",
  "vim": {
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "gutter": {
    "min_line_number_digits": 12,
  },
  "auto_update": false,
  "sticky_scroll": {
    "enabled": true,
  },
  "diff_view_style": "split",
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "eager",
    "provider": "none",
  },
  "agent": {
    "play_sound_when_agent_done": "when_hidden",
    "dock": "left",
    "use_modifier_to_send": true,
    "notify_when_agent_waiting": "never",
    "enable_feedback": false,
    "default_profile": "ask",
    "tool_permissions": {
      "tools": {
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://github\\.com",
            },
            {
              "pattern": "^https?://search\\.nixos\\.org",
            },
            {
              "pattern": "^https?://raw\\.githubusercontent\\.com",
            },
            {
              "pattern": "^https?://nixos\\.org",
            },
            {
              "pattern": "^https?://zed\\.dev",
            },
            {
              "pattern": "^https?://api\\.github\\.com",
            },
            {
              "pattern": "^https?://danklinux\\.com",
            },
            {
              "pattern": "^https?://status\\.nixos\\.org",
            },
          ],
        },
      },
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
      "effort": "high",
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
        "enable_thinking": true,
        "effort": "high",
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
        "enable_thinking": true,
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": true,
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.3-codex",
        "enable_thinking": true,
      },
    ],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
    "file_icons": true,
    "tree_view": true,
  },
  "vim_mode": true,
  "ui_font_weight": 500.0,
  "ui_font_family": "Quicksand",
  "buffer_font_family": "Google Sans Code",
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte (Blur)",
    "dark": "Catppuccin Mocha (Blur)",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "load_direnv": "shell_hook",
  "terminal": {
    "env": {
      "DIRENV_ENABLED": "1",
    },
  },
  "languages": {
    "Nix": {
      "language_servers": ["nil"],
    },
    "Lua": {
      "language_servers": ["lua-language-server"],
    },
    "Nu": {
      "language_servers": ["nushell"],
    },
    "Kdl": {
      "formatter": {
        "external": {
          "command": "kdlfmt",
          "arguments": ["format", "-", "--kdl-version", "v1"],
        },
      },
      "format_on_save": "on",
    },
  },
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "arguments": [],
      },
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
  },
  "auto_install_extensions": {
    "html": true,
    "nix": true,
    "nu": true,
    "rust": true,
    "surrealql": true,
    "toml": true,
    "biome": true,
    "catppuccin-blur": true,
    "catppuccin-icons": true,
    "csharp": true,
    "csv": true,
    "docker-compose": true,
    "dockerfile": true,
    "emmet": true,
    "ini": true,
    "lua": true,
    "powershell": true,
    "scss": true,
    "sql": true,
    "svelte": true,
    "vue": true,
    "xml": true,
    "kdl": true,
  },
}
