layout {
    gaps 8
    center-focused-column "never"
    // Transparent so the wallpaper shows through (stationary behind workspaces).
    background-color "transparent"
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }
    default-column-width {
        proportion 0.5
    }
    focus-ring {
        off
        width 1
    }
    shadow {
        on
        softness 1
        spread 0.5
        offset x=0 y=0
        draw-behind-window true
        color "#11111177"
    }
    border {
        on
        width 0.5
        active-color "#FFFFFF50"
        inactive-color "#FFFFFF15"
        urgent-color "#eb6f92"
    }
}

